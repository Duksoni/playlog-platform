  "query": "\n                SELECT account_status AS \"account_status: AccountStatus\", r.name as role\n                FROM users u\n                    INNER JOIN user_roles ur ON ur.user_id = u.id\n                    INNER JOIN roles r ON r.id = ur.role_id\n                WHERE u.id = $1\n                FOR UPDATE\n            ",
