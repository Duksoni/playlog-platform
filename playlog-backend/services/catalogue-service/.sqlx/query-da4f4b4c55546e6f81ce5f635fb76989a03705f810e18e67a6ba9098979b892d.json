  "query": "\n                UPDATE games\n                SET name = COALESCE($1, name), \n                    description = COALESCE($2, description), \n                    released = COALESCE($3, released), \n                    website = COALESCE($4, website)\n                WHERE id = $5\n                RETURNING id, name, description, released, website, draft\n             ",
